*{box-sizing:border-box}
body{
  margin:0;
  font-family:Inter,Arial,sans-serif;
  color:#fff;
  background:
    radial-gradient(circle at 10% 5%,rgba(255,47,125,.38),transparent 32%),
    radial-gradient(circle at 90% 15%,rgba(0,212,255,.25),transparent 28%),
    radial-gradient(circle at 70% 90%,rgba(124,58,237,.35),transparent 35%),
    #050510;
  overflow-x:hidden;
}
a{color:inherit;text-decoration:none}
.glow{
  position:fixed;
  width:360px;
  height:360px;
  border-radius:50%;
  filter:blur(90px);
  opacity:.55;
  pointer-events:none;
  z-index:-1;
}
.g1{top:80px;left:-120px;background:#ff2f7d}
.g2{right:-120px;bottom:80px;background:#7c3aed}
.nav{
  position:sticky;
  top:0;
  z-index:50;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:18px;
  padding:18px 28px;
  background:rgba(5,5,16,.76);
  backdrop-filter:blur(22px);
  border-bottom:1px solid rgba(255,255,255,.1);
}
.brand{display:flex;align-items:center;gap:12px}
.brand span{
  width:54px;height:54px;border-radius:18px;
  display:grid;place-items:center;
  background:conic-gradient(#ff2f7d,#7c3aed,#00d4ff,#ff2f7d);
  font-weight:1000;font-size:12px;
  box-shadow:0 0 30px rgba(255,47,125,.45);
}
.brand b{font-size:18px}
.nav-links,.nav-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.nav-links a,.nav-actions a{
  padding:10px 13px;
  border-radius:999px;
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.08);
  font-weight:800;
  font-size:14px;
}
.nav-actions .join{
  background:linear-gradient(135deg,#ff2f7d,#7c3aed);
}
.hero{
  max-width:1280px;
  margin:auto;
  padding:72px 24px 44px;
  display:grid;
  grid-template-columns:1.2fr .8fr;
  gap:34px;
  align-items:center;
}
.eyebrow,.section-head p{
  color:#ff9fbd;
  font-weight:1000;
  letter-spacing:.08em;
  font-size:13px;
}
.hero h1{
  font-size:70px;
  line-height:.95;
  letter-spacing:-3px;
  margin:16px 0;
}
.sub{
  color:#d8d8ea;
  font-size:20px;
  line-height:1.6;
  max-width:740px;
}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin:28px 0}
.primary,.secondary,.empty-card a,.phone-live a{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:15px 20px;
  border-radius:999px;
  font-weight:1000;
}
.primary,.empty-card a,.phone-live a{
  background:linear-gradient(135deg,#ff2f7d,#7c3aed);
  box-shadow:0 18px 48px rgba(255,47,125,.28);
}
.secondary{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12)}
.stats-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
}
.stats-grid div{
  padding:18px;
  border-radius:24px;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.1);
}
.stats-grid b{display:block;font-size:30px}
.stats-grid span{color:#bfc0d5;font-weight:800}
.hero-phone{
  border-radius:42px;
  padding:16px;
  background:linear-gradient(145deg,rgba(255,255,255,.16),rgba(255,255,255,.04));
  border:1px solid rgba(255,255,255,.14);
  box-shadow:0 30px 90px rgba(0,0,0,.45);
}
.phone-top{
  display:flex;
  justify-content:space-between;
  padding:12px;
  color:#ff9fbd;
  font-weight:1000;
}
.phone-live{
  min-height:520px;
  border-radius:34px;
  padding:26px;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  position:relative;
  overflow:hidden;
  background:
    linear-gradient(to top,rgba(0,0,0,.9),rgba(0,0,0,.15)),
    radial-gradient(circle at top right,rgba(0,212,255,.3),transparent 40%),
    linear-gradient(145deg,#15152b,#090912);
}
.chain-orb{
  position:absolute;
  top:22px;
  right:22px;
  width:84px;height:84px;border-radius:50%;
  display:grid;place-items:center;
  background:conic-gradient(#ff2f7d,#7c3aed,#00d4ff,#ff2f7d);
  font-weight:1000;
  animation:spin 5s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
.phone-live h3{font-size:34px;margin:0 0 10px}
.phone-live p{color:#d8d8ea}
.live-metrics{display:flex;gap:8px;flex-wrap:wrap;margin:12px 0}
.live-metrics span,.mini-row span{
  padding:9px 11px;
  border-radius:999px;
  background:rgba(255,255,255,.1);
  border:1px solid rgba(255,255,255,.08);
  font-size:13px;
  font-weight:900;
}
.section-head{
  max-width:1280px;
  margin:45px auto 18px;
  padding:0 24px;
  text-align:center;
}
.section-head.left{text-align:left;padding:0;margin:0 0 18px}
.section-head h2{
  margin:6px 0;
  font-size:42px;
  letter-spacing:-1px;
}
.live-grid,.profile-grid,.feature-wall{
  max-width:1280px;
  margin:auto;
  padding:0 24px;
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:18px;
}
.profile-grid{grid-template-columns:repeat(4,1fr)}
.live-card,.profile-card,.empty-card,.feed-card,.story-card,.feature-wall div{
  border-radius:30px;
  background:rgba(17,17,36,.84);
  border:1px solid rgba(255,255,255,.1);
  padding:22px;
  box-shadow:0 24px 70px rgba(0,0,0,.28);
}
.live-card{
  min-height:230px;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
}
.badge{color:#ff2f5f;font-weight:1000}
.live-card h3{font-size:27px;margin:12px 0}
.live-card p,.feature-wall span,.empty-card p,.feed-card span{
  color:#c7c8dc;
  line-height:1.5;
}
.mini-row{display:flex;gap:8px;flex-wrap:wrap}
.profile-card{text-align:center}
.avatar{
  width:92px;height:92px;border-radius:50%;
  margin:0 auto 14px;
  padding:4px;
  background:conic-gradient(#ff2f7d,#7c3aed,#00d4ff,#ff2f7d);
}
.avatar img,.avatar span{
  width:100%;height:100%;border-radius:50%;
  display:grid;place-items:center;
  object-fit:cover;
  background:#111124;
  font-size:36px;
  font-weight:1000;
}
.profile-card h3{margin:8px 0 4px}
.profile-card p{color:#ff9fbd;font-weight:900;margin:0}
.profile-card small{color:#bfc0d5}
.split{
  max-width:1280px;
  margin:54px auto;
  padding:0 24px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:22px;
}
.feed-list,.story-list{display:grid;gap:14px}
.feed-card img,.story-card img{
  width:100%;
  max-height:260px;
  object-fit:cover;
  border-radius:22px;
  margin-bottom:14px;
}
.story-placeholder{
  height:180px;
  border-radius:22px;
  display:grid;
  place-items:center;
  background:linear-gradient(135deg,#ff2f7d,#7c3aed);
  font-weight:1000;
  margin-bottom:14px;
}
.feature-wall{
  grid-template-columns:repeat(3,1fr);
  margin-top:44px;
}
.feature-wall b{display:block;font-size:20px;margin-bottom:8px}
footer{
  max-width:1280px;
  margin:50px auto 24px;
  padding:24px;
  border-radius:28px;
  display:flex;
  justify-content:space-between;
  gap:18px;
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.1);
}
footer span{color:#c7c8dc}
@media(max-width:1100px){
  .hero,.split{grid-template-columns:1fr}
  .hero h1{font-size:52px}
  .live-grid,.profile-grid,.feature-wall{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:760px){
  .nav{position:relative;flex-direction:column;align-items:flex-start}
  .hero{padding-top:36px}
  .hero h1{font-size:42px}
  .stats-grid,.live-grid,.profile-grid,.feature-wall{grid-template-columns:1fr}
  .phone-live{min-height:420px}
  .section-head h2{font-size:32px}
  footer{flex-direction:column}
}
