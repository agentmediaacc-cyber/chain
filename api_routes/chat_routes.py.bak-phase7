from flask import Blueprint, render_template, request, redirect, url_for
from services.chat_service import (
    get_conversations,
    get_conversation,
    send_message,
    start_chat_with_username,
)
from api_routes.profile_routes import login_required

chat_bp = Blueprint("chat", __name__, url_prefix="/chat")


@chat_bp.route("/")
@login_required
def inbox():
    conversations, current = get_conversations()
    return render_template(
        "chat/inbox.html",
        chats=conversations,
        conversations=conversations,
        current=current,
        message=request.args.get("message"),
    )


@chat_bp.route("/start/<username>")
@login_required
def start(username):
    convo, error = start_chat_with_username(username)
    if convo:
        return redirect(f"/chat/thread/{convo['id']}")
    return redirect(url_for("chat.inbox", message=error or "Chat is unavailable right now."))


@chat_bp.route("/thread/<thread_id>")
@chat_bp.route("/<thread_id>")
@login_required
def thread(thread_id):
    convo, messages, current, error = get_conversation(thread_id)
    if error:
        return render_template("chat/error.html", error=error)

    return render_template("chat/thread.html", convo=convo, messages=messages, current=current)


@chat_bp.route("/thread/<thread_id>/send", methods=["POST"])
@login_required
def send_thread_message(thread_id):
    ok, error = send_message(thread_id, request.form.get("message"))
    if not ok:
        return redirect(url_for("chat.inbox", message=error or "Message could not be sent."))
    return redirect(url_for("chat.thread", thread_id=thread_id))
