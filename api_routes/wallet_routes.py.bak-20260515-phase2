from flask import Blueprint, render_template, request, redirect, url_for
from services.wallet_service import (
    get_wallet_home,
    top_up_wallet,
    get_gift_page,
    send_gift_to_username,
)
from api_routes.profile_routes import login_required

wallet_bp = Blueprint("wallet", __name__, url_prefix="/wallet")


@wallet_bp.route("/")
@login_required
def wallet_home():
    current, wallet, gifts, transactions = get_wallet_home()
    return render_template(
        "wallet/index.html",
        current=current,
        wallet=wallet,
        gifts=gifts,
        transactions=transactions,
    )


@wallet_bp.route("/top-up", methods=["POST"])
@login_required
def top_up():
    top_up_wallet(request.form.get("coins"))
    return redirect(url_for("wallet.wallet_home"))


@wallet_bp.route("/gift/<username>", methods=["GET", "POST"])
@login_required
def gift_user(username):
    if request.method == "POST":
        ok, msg = send_gift_to_username(username, request.form.get("gift_id"))
        return redirect(url_for("wallet.wallet_home"))

    current, receiver, wallet, gifts = get_gift_page(username)
    return render_template(
        "wallet/gift.html",
        current=current,
        receiver=receiver,
        wallet=wallet,
        gifts=gifts,
    )
