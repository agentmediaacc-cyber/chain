from flask import Blueprint, render_template

from api_routes.profile_routes import login_required
from services.profile_service import get_current_profile, get_profile_by_username
from services.supabase_safe import safe_insert, table_exists

call_bp = Blueprint("calls", __name__, url_prefix="/calls")


@call_bp.route("/video/<username>")
@login_required
def video_call(username):
    viewer = get_current_profile()
    target = get_profile_by_username(username)
    if not target:
        return render_template("profile/not_found.html", username=username), 404

    call_record = None
    if table_exists("chain_video_calls"):
        created = safe_insert(
            "chain_video_calls",
            {
                "caller_profile_id": viewer["id"],
                "receiver_profile_id": target["id"],
                "status": "started",
                "call_type": "video",
            },
            fallback_columns={"caller_profile_id", "receiver_profile_id", "status", "call_type", "created_at"},
        )
        if created:
            call_record = created[0]

    return render_template("calls/video.html", viewer=viewer, target=target, call_record=call_record)
