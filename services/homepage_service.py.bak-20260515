from datetime import datetime, timezone

from engines.cache_engine import cache_key, get_cache, set_cache
from services.live_service import get_live_rooms
from services.notification_service import get_my_notifications
from services.profile_service import get_current_profile, normalize_profile
from services.supabase_safe import safe_count, safe_select


def _derive_categories(live_rooms, posts):
    seen = set()
    categories = []

    for item in list(live_rooms) + list(posts):
        category = (item or {}).get("category")
        if not category:
            continue

        label = str(category).strip()
        key = label.lower()
        if not label or key in seen:
            continue

        seen.add(key)
        categories.append({"name": label, "icon": "•"})

    return categories[:8]


def _provider_counts():
    provider_rows = safe_select(
        "chain_profiles",
        columns="id,auth_provider,linked_providers,password_set,profile_completed",
        limit=2000,
    )
    google_users = 0
    facebook_users = 0
    email_users = 0
    for row in provider_rows:
        linked = row.get("linked_providers") or []
        if isinstance(linked, str):
            linked = [item.strip() for item in linked.split(",") if item.strip()]
        if row.get("auth_provider") == "google" or "google" in linked:
            google_users += 1
        if row.get("auth_provider") == "facebook" or "facebook" in linked:
            facebook_users += 1
        if row.get("password_set"):
            email_users += 1
    return google_users, facebook_users, email_users


def get_homepage_data():
    try:
        current = get_current_profile()
        notifications, _, unread_count = get_my_notifications(limit=6)
        homepage_key = cache_key("homepage_data", "public")
        cached_data = get_cache(homepage_key)
        if cached_data is None:
            live_rooms = get_live_rooms(limit=6)
            profiles = [
                normalize_profile(profile)
                for profile in safe_select(
                    "chain_profiles",
                    columns="id,username,full_name,bio,current_location,avatar_url,is_premium,premium_tier,is_verified,age,country_origin,interests,cover_url",
                    limit=12,
                    filters={"is_public": True},
                )
            ]
            posts = safe_select("chain_posts", columns="id,profile_id,body,caption,media_url,visibility,created_at,category", limit=6)
            stories = safe_select("chain_stories", columns="id,profile_id,caption,media_url,status,created_at", limit=8)
            trending_categories = _derive_categories(
                get_live_rooms(limit=20),
                safe_select("chain_posts", columns="id,category", limit=20),
            )

            today_prefix = datetime.now(timezone.utc).date().isoformat()
            today_logins = safe_count("chain_login_events", filters={"created_at": ("gte", f"{today_prefix}T00:00:00+00:00")})
            google_users, facebook_users, email_users = _provider_counts()
            stats = {
                "profiles": safe_count("chain_profiles"),
                "total_users": safe_count("chain_profiles"),
                "active_profiles": safe_count("chain_profiles", filters={"profile_completed": True}),
                "completed_users": safe_count("chain_profiles", filters={"profile_completed": True}),
                "premium_users": safe_count("chain_profiles", filters={"is_premium": True}),
                "google_users": google_users,
                "facebook_users": facebook_users,
                "email_users": email_users,
                "today_logins": today_logins,
                "posts": safe_count("chain_posts"),
                "stories": safe_count("chain_stories"),
                "live_rooms": safe_count("chain_live_rooms", filters={"status": "live"}),
                "gifts": safe_count("chain_live_gifts"),
            }
            cached_data = {
                "stats": stats,
                "live_rooms": live_rooms,
                "profiles": profiles,
                "posts": posts,
                "stories": stories,
                "trending_categories": trending_categories,
            }
            set_cache(homepage_key, cached_data, ttl=45)

        return {
            "current": current,
            "unread_count": unread_count,
            "stats": cached_data["stats"],
            "live_rooms": cached_data["live_rooms"],
            "profiles": cached_data["profiles"],
            "posts": cached_data["posts"],
            "stories": cached_data["stories"],
            "notifications": notifications,
            "trending_categories": cached_data["trending_categories"],
        }
    except Exception as error:
        print(f"[homepage_service] get_homepage_data failed: {error}")
        return {
            "current": None,
            "unread_count": 0,
            "stats": {"profiles": 0, "total_users": 0, "completed_users": 0, "active_profiles": 0, "premium_users": 0, "google_users": 0, "facebook_users": 0, "email_users": 0, "today_logins": 0, "posts": 0, "stories": 0, "live_rooms": 0, "gifts": 0},
            "live_rooms": [],
            "profiles": [],
            "posts": [],
            "stories": [],
            "notifications": [],
            "trending_categories": [],
        }
