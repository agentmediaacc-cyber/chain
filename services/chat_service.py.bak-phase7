from datetime import datetime, timezone

from utils.supabase_client import get_supabase_admin
from services.notification_service import create_notification
from services.profile_service import get_current_profile, normalize_profile
from services.supabase_safe import safe_insert, safe_select, safe_update, table_exists


def _utcnow_iso():
    return datetime.now(timezone.utc).isoformat()


def _thread_table():
    if table_exists("chain_chat_threads"):
        return "chain_chat_threads"
    if table_exists("chain_chat_conversations"):
        return "chain_chat_conversations"
    return None


def _message_fk():
    return "thread_id" if _thread_table() == "chain_chat_threads" else "conversation_id"


def get_profile_by_id(profile_id):
    rows = safe_select("chain_profiles", filters={"id": profile_id}, limit=1, order_by=None)
    return normalize_profile(rows[0]) if rows else None


def _find_target_by_username(username):
    rows = safe_select("chain_profiles", filters={"username": username}, limit=1)
    return normalize_profile(rows[0]) if rows else None


def get_or_create_conversation(target_profile_id):
    try:
        table = _thread_table()
        if not table:
            return None, "Chat threads table is missing."

        supabase = get_supabase_admin()
        current = get_current_profile()
        if not current:
            return None, "Create your profile first."
        if current["id"] == target_profile_id:
            return None, "You cannot chat with your own profile."

        existing = (
            supabase.table(table)
            .select("*")
            .or_(
                f"and(profile_one_id.eq.{current['id']},profile_two_id.eq.{target_profile_id}),"
                f"and(profile_one_id.eq.{target_profile_id},profile_two_id.eq.{current['id']})"
            )
            .limit(1)
            .execute()
            .data
        )
        if existing:
            return existing[0], None

        target = get_profile_by_id(target_profile_id)
        title = f"{current.get('full_name')} & {target.get('full_name') if target else 'Chain Member'}"
        created = safe_insert(
            table,
            {
                "profile_one_id": current["id"],
                "profile_two_id": target_profile_id,
                "title": title,
                "status": "active",
                "last_message_at": _utcnow_iso(),
                "created_at": _utcnow_iso(),
            },
            fallback_columns={"profile_one_id", "profile_two_id", "title", "status", "last_message_at", "created_at"},
        )
        return created[0] if created else None, None
    except Exception as error:
        print(f"[chat_service] get_or_create_conversation failed: {error}")
        return None, "Chat is unavailable right now."


def get_conversations():
    try:
        table = _thread_table()
        current = get_current_profile()
        if not current or not table:
            return [], current

        supabase = get_supabase_admin()
        rows = (
            supabase.table(table)
            .select("*")
            .or_(f"profile_one_id.eq.{current['id']},profile_two_id.eq.{current['id']}")
            .order("last_message_at", desc=True)
            .execute()
            .data or []
        )

        conversations = []
        for row in rows:
            other_id = row["profile_two_id"] if row["profile_one_id"] == current["id"] else row["profile_one_id"]
            other = get_profile_by_id(other_id)
            row["other_profile"] = other
            row["chat_title"] = (other or {}).get("full_name") or row.get("title") or "Conversation"
            conversations.append(row)
        return conversations, current
    except Exception as error:
        print(f"[chat_service] get_conversations failed: {error}")
        return [], get_current_profile()


def get_conversation(thread_id):
    try:
        table = _thread_table()
        current = get_current_profile()
        if not current:
            return None, [], None, "Create your profile first."
        if not table:
            return None, [], current, "Chat threads table is missing."

        supabase = get_supabase_admin()
        convo = (
            supabase.table(table)
            .select("*")
            .eq("id", thread_id)
            .limit(1)
            .execute()
            .data
        )
        if not convo:
            return None, [], current, "Conversation not found."

        convo = convo[0]
        other_id = convo["profile_two_id"] if convo["profile_one_id"] == current["id"] else convo["profile_one_id"]
        convo["other_profile"] = get_profile_by_id(other_id)

        messages = (
            supabase.table("chain_chat_messages")
            .select("*")
            .eq(_message_fk(), thread_id)
            .order("created_at")
            .execute()
            .data or []
        ) if table_exists("chain_chat_messages") else []

        for message in messages:
            if "body" not in message or not message.get("body"):
                message["body"] = message.get("message") or ""

        return convo, messages, current, None
    except Exception as error:
        print(f"[chat_service] get_conversation failed: {error}")
        return None, [], get_current_profile(), "Chat is unavailable right now."


def send_message(thread_id, text):
    try:
        current = get_current_profile()
        if not current:
            return False, "Create your profile first."

        text = (text or "").strip()
        if not text:
            return False, "Message cannot be empty."

        convo, messages, current, error = get_conversation(thread_id)
        if error:
            return False, error

        receiver_id = convo["profile_two_id"] if convo["profile_one_id"] == current["id"] else convo["profile_one_id"]
        if table_exists("chain_chat_messages"):
            safe_insert(
                "chain_chat_messages",
                {
                    _message_fk(): thread_id,
                    "thread_id": thread_id,
                    "conversation_id": thread_id,
                    "sender_profile_id": current["id"],
                    "receiver_profile_id": receiver_id,
                    "body": text,
                    "message": text,
                    "message_type": "text",
                    "created_at": _utcnow_iso(),
                },
                fallback_columns={"thread_id", "conversation_id", "sender_profile_id", "receiver_profile_id", "body", "message", "message_type", "created_at"},
            )

        safe_update(
            _thread_table(),
            {"last_message": text, "last_message_at": _utcnow_iso(), "status": "active"},
            eq={"id": thread_id},
            fallback_columns={"last_message", "last_message_at", "status"},
        )

        create_notification(
            receiver_id,
            "💬 New Message",
            f"{current.get('full_name')} sent you a message.",
            "message",
            f"/chat/thread/{thread_id}",
        )
        return True, None
    except Exception as error:
        print(f"[chat_service] send_message failed: {error}")
        return False, "Message could not be sent right now."


def start_chat_with_username(username):
    try:
        target = _find_target_by_username(username)
        if not target:
            return None, "Profile not found."
        return get_or_create_conversation(target["id"])
    except Exception as error:
        print(f"[chat_service] start_chat_with_username failed: {error}")
        return None, "Chat is unavailable right now."
