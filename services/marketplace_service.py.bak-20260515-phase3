from datetime import datetime, timezone

from services.supabase_safe import safe_insert, safe_select, safe_update
from services.wallet_action_service import get_or_create_wallet

COIN_VALUE_NAD = 5


def _utcnow_iso():
    return datetime.now(timezone.utc).isoformat()


def create_album(profile_id, title, description, genre, cover_url, price_coins):
    payload = {
        "profile_id": profile_id,
        "title": title,
        "description": description,
        "genre": genre,
        "album_cover_url": cover_url,
        "price_coins": int(price_coins or 0),
        "approval_status": "pending",
        "is_public": False,
        "created_at": _utcnow_iso(),
        "updated_at": _utcnow_iso(),
    }
    inserted = safe_insert("chain_music_albums", payload)
    return inserted[0] if inserted else payload


def create_track(profile_id, album_id, title, audio_url, price_coins):
    payload = {
        "album_id": album_id,
        "profile_id": profile_id,
        "title": title,
        "audio_url": audio_url,
        "price_coins": int(price_coins or 0),
        "price_nad": int(price_coins or 0) * COIN_VALUE_NAD,
        "approval_status": "pending",
        "is_public": False,
        "created_at": _utcnow_iso(),
        "updated_at": _utcnow_iso(),
    }
    inserted = safe_insert("chain_music_tracks", payload)
    return inserted[0] if inserted else payload


def create_marketplace_item(profile_id, item_type, title, description, media_url, cover_url, price_coins, premium_locked):
    payload = {
        "profile_id": profile_id,
        "item_type": item_type,
        "title": title,
        "description": description,
        "media_url": media_url,
        "cover_url": cover_url,
        "price_coins": int(price_coins or 0),
        "price_nad": int(price_coins or 0) * COIN_VALUE_NAD,
        "is_premium_locked": bool(premium_locked),
        "approval_status": "pending",
        "moderation_status": "pending",
        "is_public": False,
        "created_at": _utcnow_iso(),
        "updated_at": _utcnow_iso(),
    }
    inserted = safe_insert("chain_marketplace_items", payload)
    return inserted[0] if inserted else payload


def list_my_items(profile_id):
    return safe_select("chain_marketplace_items", filters={"profile_id": profile_id}, limit=50)


def list_public_items():
    items = safe_select("chain_marketplace_items", filters={"is_public": True}, limit=50)
    return [item for item in items if item.get("approval_status") == "approved" or item.get("moderation_status") == "approved"]


def get_item(item_id):
    rows = safe_select("chain_marketplace_items", filters={"id": item_id}, limit=1, order_by=None)
    return rows[0] if rows else None


def purchase_item(buyer_profile_id, item_id):
    item = get_item(item_id)
    if not item:
      return False, "Item not found."
    wallet = get_or_create_wallet(buyer_profile_id)
    price_coins = int(item.get("price_coins") or 0)
    available = int(wallet.get("available_balance") or wallet.get("coin_balance") or 0)
    if price_coins > available:
        return False, "Insufficient coins."

    safe_update(
        "chain_wallets",
        {
            "available_balance": available - price_coins,
            "coin_balance": available - price_coins,
            "updated_at": _utcnow_iso(),
        },
        eq={"profile_id": buyer_profile_id},
    )
    safe_insert(
        "chain_media_purchases",
        {
            "buyer_profile_id": buyer_profile_id,
            "item_id": item_id,
            "item_type": item.get("item_type"),
            "amount_nad": item.get("price_nad") or (price_coins * COIN_VALUE_NAD),
            "coins_spent": price_coins,
            "status": "completed",
            "created_at": _utcnow_iso(),
        },
    )
    return True, item


def approve_marketplace_item(item_id):
    item = get_item(item_id)
    if not item:
        return False, "Marketplace item not found."
    safe_update(
        "chain_marketplace_items",
        {
            "approval_status": "approved",
            "moderation_status": "approved",
            "is_public": True,
            "updated_at": _utcnow_iso(),
        },
        eq={"id": item_id},
    )
    return True, item
