<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Chain Premium Live Studio</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/static/css/live_studio.css">
</head>
<body>
  <main class="studio-shell">
    <section class="preview-stage">
      <div class="chain-logo-orbit" id="chainLogo">CHAIN</div>
      <div class="moving-watermark">CHAIN LIVE • PREMIUM STREAMING • NAMIBIA</div>

      <video id="cameraPreview" autoplay playsinline muted></video>

      <div class="empty-camera" id="emptyCamera">
        <h1>CHAIN LIVE STUDIO</h1>
        <p>Camera is off. Tap “Start Camera” to preview before going live.</p>
      </div>

      <div class="live-badge">● LIVE READY</div>

      <div class="viewer-strip">
        <span>👥 0 viewers</span>
        <span>🎁 Gifts ready</span>
        <span>💬 Comments on</span>
        <span>🎙 Guests enabled</span>
      </div>

      <div class="comment-float">
        <div><b>Aina</b> joined your live</div>
        <div><b>Simon</b> sent 🔥🔥🔥</div>
        <div><b>Maria</b> replied: Premium room looks clean</div>
      </div>
    </section>

    <aside class="control-panel">
      <div class="panel-head">
        <p>Creator Control Room</p>
        <h2>Premium Stream Setup</h2>
      </div>

      <div class="button-grid">
        <button type="button" onclick="startCamera()">📷 Start Camera</button>
        <button type="button" onclick="shareScreen()">🖥 Share Screen</button>
        <button type="button" onclick="stopMedia()">⏹ Stop</button>
        <button type="button" onclick="moveLogo()">🔁 Move Logo</button>
      </div>

      <form method="POST" enctype="multipart/form-data" class="live-form">
        <label>Live Title</label>
        <input name="title" value="My Chain Live Room" placeholder="Live title">

        <label>Welcome Message</label>
        <textarea name="welcome_message">Thank you for joining my live channel ❤️</textarea>

        <label>YouTube Video / Music Link</label>
        <input name="youtube_url" placeholder="https://youtu.be/...">

        <label>Upload MP3 Music</label>
        <input type="file" name="mp3_file" accept="audio/mpeg,audio/mp3">

        <div class="two">
          <div>
            <label>Access</label>
            <select name="access_type">
              <option value="public">Public</option>
              <option value="premium">Premium Members</option>
              <option value="wallet">Wallet Balance Required</option>
              <option value="private">Private Invite</option>
            </select>
          </div>
          <div>
            <label>Entry Fee</label>
            <input name="entry_fee" type="number" value="0" min="0">
          </div>
        </div>

        <div class="feature-toggles">
          <label><input type="checkbox" name="comments_enabled" checked> Enable comments</label>
          <label><input type="checkbox" name="gifts_enabled" checked> Enable gifts</label>
          <label><input type="checkbox" name="cohost_enabled" checked> Allow co-hosts</label>
          <label><input type="checkbox" name="music_enabled" checked> Music deck</label>
          <label><input type="checkbox" name="conference_mode"> Conference mode</label>
          <label><input type="checkbox" name="premium_only"> Premium lock</label>
        </div>

        <button class="start-live" type="submit">🔴 Start Premium Live Room</button>
      </form>
    </aside>
  </main>

  <script src="/static/js/live_studio.js"></script>
</body>
</html>
