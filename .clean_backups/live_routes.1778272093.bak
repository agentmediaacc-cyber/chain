import os
from werkzeug.utils import secure_filename
from flask import Blueprint, render_template, request, redirect, url_for
from services.live_service import (
    create_room,
    get_live_rooms,
    get_room_data,
    add_comment,
    follow_host,
    block_viewer,
    send_live_gift,
    end_room,
)

live_bp = Blueprint("live", __name__, url_prefix="/live")


@live_bp.route("/")
def live_home():
    rooms = get_live_rooms()
    return render_template("live/home.html", rooms=rooms)


@live_bp.route("/studio", methods=["GET", "POST"])
def studio():
    if request.method == "POST":
        mp3_url = None
        mp3 = request.files.get("mp3_file")
        if mp3 and mp3.filename:
            os.makedirs("static/uploads/live_music", exist_ok=True)
            filename = secure_filename(mp3.filename)
            path = os.path.join("static/uploads/live_music", filename)
            mp3.save(path)
            mp3_url = "/" + path

        data = dict(request.form)
        data["mp3_url"] = mp3_url
        data["comments_enabled"] = request.form.get("comments_enabled") == "on"

        room, error = create_room(data)
        if room:
            return redirect(url_for("live.room", room_id=room["id"]))
        return render_template("live/studio.html", error=error)

    return render_template("live/studio.html", error=None)


@live_bp.route("/room/<room_id>")
def room(room_id):
    room, current, comments, viewers, gifts, error = get_room_data(room_id)
    if error:
        return render_template("live/locked.html", error=error, room=room)
    return render_template(
        "live/room.html",
        room=room,
        current=current,
        comments=comments,
        viewers=viewers,
        gifts=gifts,
    )


@live_bp.route("/room/<room_id>/comment", methods=["POST"])
def comment(room_id):
    add_comment(room_id, request.form.get("comment"), request.form.get("parent_comment_id"))
    return redirect(url_for("live.room", room_id=room_id))


@live_bp.route("/room/<room_id>/follow")
def follow(room_id):
    follow_host(room_id)
    return redirect(url_for("live.room", room_id=room_id))


@live_bp.route("/room/<room_id>/block/<profile_id>")
def block(room_id, profile_id):
    block_viewer(room_id, profile_id)
    return redirect(url_for("live.room", room_id=room_id))


@live_bp.route("/room/<room_id>/gift", methods=["POST"])
def gift(room_id):
    send_live_gift(
        room_id,
        request.form.get("gift_name"),
        request.form.get("emoji"),
        request.form.get("coins"),
    )
    return redirect(url_for("live.room", room_id=room_id))


@live_bp.route("/room/<room_id>/end")
def end(room_id):
    end_room(room_id)
    return redirect(url_for("live.live_home"))
