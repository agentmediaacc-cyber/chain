*{box-sizing:border-box}
body{
  margin:0;
  font-family:Inter,Arial,sans-serif;
  color:white;
  min-height:100vh;
  background:
    radial-gradient(circle at top left,rgba(255,45,125,.35),transparent 35%),
    radial-gradient(circle at bottom right,rgba(124,58,237,.35),transparent 35%),
    #050510;
}
.studio-shell{
  display:grid;
  grid-template-columns:1.7fr .9fr;
  gap:22px;
  padding:22px;
  min-height:100vh;
}
.preview-stage{
  position:relative;
  overflow:hidden;
  border-radius:34px;
  background:linear-gradient(145deg,#090912,#16162a);
  border:1px solid rgba(255,255,255,.12);
  box-shadow:0 30px 90px rgba(0,0,0,.55);
  min-height:720px;
}
#cameraPreview{
  width:100%;
  height:100%;
  min-height:720px;
  object-fit:cover;
  display:none;
  background:#000;
}
.empty-camera{
  position:absolute;
  inset:0;
  display:grid;
  place-content:center;
  text-align:center;
  padding:30px;
}
.empty-camera h1{
  font-size:64px;
  margin:0;
  letter-spacing:-2px;
}
.empty-camera p{color:#cfcfe8;font-size:18px}
.chain-logo-orbit{
  position:absolute;
  top:22px;
  right:22px;
  z-index:20;
  width:86px;
  height:86px;
  border-radius:50%;
  display:grid;
  place-items:center;
  font-weight:1000;
  background:conic-gradient(from 0deg,#ff2f7d,#7c3aed,#00d4ff,#ff2f7d);
  color:white;
  box-shadow:0 0 35px rgba(255,47,125,.55);
  animation:spin 5s linear infinite, glow 2s ease-in-out infinite alternate;
}
.chain-logo-orbit.left{left:22px;right:auto}
.chain-logo-orbit.bottom{top:auto;bottom:22px}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes glow{from{filter:brightness(1)}to{filter:brightness(1.45)}}
.moving-watermark{
  position:absolute;
  z-index:10;
  top:45%;
  left:-420px;
  color:rgba(255,255,255,.18);
  font-size:34px;
  font-weight:1000;
  white-space:nowrap;
  animation:slideWatermark 13s linear infinite;
}
@keyframes slideWatermark{to{left:110%}}
.live-badge{
  position:absolute;
  top:24px;
  left:24px;
  padding:12px 16px;
  border-radius:999px;
  background:rgba(255,0,68,.22);
  border:1px solid rgba(255,0,68,.5);
  font-weight:900;
}
.viewer-strip{
  position:absolute;
  left:24px;
  right:24px;
  bottom:24px;
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
}
.viewer-strip span{
  padding:14px;
  border-radius:18px;
  background:rgba(0,0,0,.45);
  backdrop-filter:blur(18px);
  border:1px solid rgba(255,255,255,.12);
  font-weight:800;
}
.comment-float{
  position:absolute;
  right:24px;
  bottom:120px;
  width:320px;
  display:grid;
  gap:10px;
}
.comment-float div{
  padding:12px 14px;
  border-radius:18px;
  background:rgba(0,0,0,.45);
  backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,.12);
}
.control-panel{
  border-radius:34px;
  padding:24px;
  background:rgba(15,15,30,.88);
  border:1px solid rgba(255,255,255,.12);
  box-shadow:0 30px 80px rgba(0,0,0,.45);
  overflow:auto;
}
.panel-head p{
  color:#ff8ab8;
  font-weight:1000;
  margin:0;
}
.panel-head h2{
  font-size:34px;
  margin:8px 0 20px;
}
.button-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  margin-bottom:22px;
}
button,.start-live{
  border:0;
  cursor:pointer;
  padding:14px 16px;
  border-radius:18px;
  font-weight:1000;
  color:white;
  background:linear-gradient(135deg,#252542,#111122);
  border:1px solid rgba(255,255,255,.13);
}
.live-form{display:grid;gap:13px}
label{font-weight:900;color:#f4f4ff}
input,textarea,select{
  width:100%;
  border:1px solid rgba(255,255,255,.15);
  background:#090912;
  color:white;
  border-radius:17px;
  padding:14px;
  outline:none;
}
textarea{min-height:82px}
.two{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.feature-toggles{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  padding:14px;
  border-radius:20px;
  background:rgba(255,255,255,.06);
}
.feature-toggles label{
  font-size:13px;
  color:#ddd;
}
.start-live{
  margin-top:8px;
  background:linear-gradient(135deg,#ff2f7d,#7c3aed);
  box-shadow:0 16px 40px rgba(255,47,125,.3);
}
@media(max-width:1050px){
  .studio-shell{grid-template-columns:1fr}
  .preview-stage,#cameraPreview{min-height:520px}
}
@media(max-width:650px){
  .studio-shell{padding:12px}
  .empty-camera h1{font-size:38px}
  .viewer-strip{grid-template-columns:1fr 1fr}
  .comment-float{display:none}
  .two,.feature-toggles,.button-grid{grid-template-columns:1fr}
}
