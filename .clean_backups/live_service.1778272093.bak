import re
from utils.supabase_client import get_supabase_admin
from services.matching_service import get_current_profile
from services.wallet_service import ensure_wallet
from services.notification_service import create_notification


def youtube_embed(url):
    if not url:
        return None
    patterns = [
        r"youtu\.be/([^?&/]+)",
        r"youtube\.com/watch\?v=([^?&/]+)",
        r"youtube\.com/embed/([^?&/]+)",
        r"youtube\.com/shorts/([^?&/]+)",
    ]
    for p in patterns:
        m = re.search(p, url)
        if m:
            return f"https://www.youtube.com/embed/{m.group(1)}"
    return None


def create_room(data):
    supabase = get_supabase_admin()
    current = get_current_profile()
    if not current:
        return None, "Create your profile first."

    embed = youtube_embed(data.get("youtube_url"))

    created = supabase.table("chain_live_rooms").insert({
        "host_profile_id": current["id"],
        "title": data.get("title") or f"{current['full_name']} Live",
        "welcome_message": data.get("welcome_message") or "",
        "youtube_url": data.get("youtube_url") or None,
        "youtube_embed_url": embed,
        "mp3_url": data.get("mp3_url") or None,
        "access_type": data.get("access_type") or "public",
        "comments_enabled": bool(data.get("comments_enabled", True)),
        "is_live": True,
    }).execute().data

    room = created[0]
    join_room(room["id"])
    return room, None


def get_live_rooms(limit=20):
    supabase = get_supabase_admin()
    return (
        supabase.table("chain_live_rooms")
        .select("*, chain_profiles!chain_live_rooms_host_profile_id_fkey(*)")
        .eq("is_live", True)
        .order("created_at", desc=True)
        .limit(limit)
        .execute()
        .data or []
    )


def get_room(room_id):
    supabase = get_supabase_admin()
    rows = (
        supabase.table("chain_live_rooms")
        .select("*")
        .eq("id", room_id)
        .limit(1)
        .execute()
        .data or []
    )
    if not rows:
        return None
    room = rows[0]
    host = (
        supabase.table("chain_profiles")
        .select("*")
        .eq("id", room["host_profile_id"])
        .limit(1)
        .execute()
        .data or []
    )
    room["host"] = host[0] if host else None
    return room


def can_access_room(room, current):
    if not room:
        return False, "Live room not found."
    if not current:
        return False, "Create your profile first."
    if room["host_profile_id"] == current["id"]:
        return True, None
    if room.get("access_type") == "public":
        return True, None

    wallet = ensure_wallet(current["id"])
    if int(wallet.get("coin_balance") or 0) > 0:
        return True, None

    return False, "This is a premium live. Add coins to your wallet first."


def join_room(room_id):
    supabase = get_supabase_admin()
    current = get_current_profile()
    if not current:
        return None

    room = get_room(room_id)
    if not room:
        return None

    blocked = (
        supabase.table("chain_live_blocks")
        .select("id")
        .eq("room_id", room_id)
        .eq("blocked_profile_id", current["id"])
        .limit(1)
        .execute()
        .data
    )
    if blocked:
        return None

    try:
        supabase.table("chain_live_viewers").insert({
            "room_id": room_id,
            "profile_id": current["id"],
        }).execute()
    except Exception:
        pass

    count = (
        supabase.table("chain_live_viewers")
        .select("id", count="exact")
        .eq("room_id", room_id)
        .is_("left_at", "null")
        .execute()
        .count or 0
    )

    supabase.table("chain_live_rooms").update({"viewer_count": count}).eq("id", room_id).execute()
    return current


def get_room_data(room_id):
    supabase = get_supabase_admin()
    current = get_current_profile()
    room = get_room(room_id)

    ok, error = can_access_room(room, current)
    if not ok:
        return room, current, [], [], [], error

    join_room(room_id)

    comments = (
        supabase.table("chain_live_comments")
        .select("*")
        .eq("room_id", room_id)
        .order("created_at", desc=True)
        .limit(80)
        .execute()
        .data or []
    )

    viewers = (
        supabase.table("chain_live_viewers")
        .select("*, chain_profiles(*)")
        .eq("room_id", room_id)
        .is_("left_at", "null")
        .execute()
        .data or []
    )

    gifts = (
        supabase.table("chain_live_gifts")
        .select("*")
        .eq("room_id", room_id)
        .order("created_at", desc=True)
        .limit(20)
        .execute()
        .data or []
    )

    return room, current, comments, viewers, gifts, None


def add_comment(room_id, comment, parent_id=None):
    supabase = get_supabase_admin()
    current = get_current_profile()
    room = get_room(room_id)

    if not current or not room or not room.get("comments_enabled"):
        return False

    comment = (comment or "").strip()
    if not comment:
        return False

    supabase.table("chain_live_comments").insert({
        "room_id": room_id,
        "profile_id": current["id"],
        "parent_comment_id": parent_id or None,
        "comment": comment,
    }).execute()

    return True


def follow_host(room_id):
    supabase = get_supabase_admin()
    current = get_current_profile()
    room = get_room(room_id)
    if not current or not room or current["id"] == room["host_profile_id"]:
        return False

    try:
        supabase.table("chain_follows").insert({
            "follower_profile_id": current["id"],
            "following_profile_id": room["host_profile_id"],
        }).execute()
    except Exception:
        pass

    create_notification(
        room["host_profile_id"],
        "🔔 New follower",
        f"{current['full_name']} followed you from your live room.",
        "follow",
        f"/live/room/{room_id}",
    )
    return True


def block_viewer(room_id, profile_id):
    supabase = get_supabase_admin()
    current = get_current_profile()
    room = get_room(room_id)
    if not current or not room or room["host_profile_id"] != current["id"]:
        return False

    try:
        supabase.table("chain_live_blocks").insert({
            "room_id": room_id,
            "blocked_profile_id": profile_id,
        }).execute()
    except Exception:
        pass

    return True


def send_live_gift(room_id, gift_name, emoji, coins):
    supabase = get_supabase_admin()
    current = get_current_profile()
    room = get_room(room_id)
    if not current or not room:
        return False, "Profile or room missing."

    coins = int(coins or 0)
    wallet = ensure_wallet(current["id"])
    host_wallet = ensure_wallet(room["host_profile_id"])

    if current["id"] == room["host_profile_id"]:
        return False, "Host cannot gift themselves."

    if int(wallet.get("coin_balance") or 0) < coins:
        return False, "Not enough coins."

    supabase.table("chain_wallets").update({
        "coin_balance": int(wallet.get("coin_balance") or 0) - coins,
        "total_spent": int(wallet.get("total_spent") or 0) + coins,
    }).eq("profile_id", current["id"]).execute()

    supabase.table("chain_wallets").update({
        "gift_earnings": int(host_wallet.get("gift_earnings") or 0) + coins,
        "total_received": int(host_wallet.get("total_received") or 0) + coins,
    }).eq("profile_id", room["host_profile_id"]).execute()

    supabase.table("chain_live_gifts").insert({
        "room_id": room_id,
        "sender_profile_id": current["id"],
        "host_profile_id": room["host_profile_id"],
        "gift_name": gift_name,
        "emoji": emoji,
        "coins": coins,
    }).execute()

    total = int(room.get("total_gift_coins") or 0) + coins
    supabase.table("chain_live_rooms").update({"total_gift_coins": total}).eq("id", room_id).execute()

    create_notification(
        room["host_profile_id"],
        f"{emoji} Live gift received",
        f"{current['full_name']} sent {gift_name} worth {coins} coins.",
        "gift",
        f"/live/room/{room_id}",
    )
    return True, "Gift sent."


def end_room(room_id):
    supabase = get_supabase_admin()
    current = get_current_profile()
    room = get_room(room_id)
    if current and room and current["id"] == room["host_profile_id"]:
        supabase.table("chain_live_rooms").update({
            "is_live": False,
            "ended_at": "now()",
        }).eq("id", room_id).execute()
        return True
    return False
