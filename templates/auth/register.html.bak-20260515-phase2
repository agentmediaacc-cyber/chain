{% extends "base.html" %}

{% block title %}Join Chain | Premium Registration{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="/static/css/auth_premium.css">
{% endblock %}

{% block content %}
<div class="auth-page">
    <div class="auth-card" style="max-width: 600px;">
        <div class="auth-header">
            <h1>Join Chain</h1>
            <p>Create your account, then finish your full CHAIN profile before you start meeting, streaming and earning.</p>
        </div>

        {% if error %}
        <div class="error-msg">
            <i class="fas fa-exclamation-circle"></i> {{ error }}
        </div>
        {% endif %}

        <div class="oauth-buttons" style="margin-bottom: 20px;">
            <a href="/auth/google" class="oauth-btn oauth-trigger" data-loading="Connecting to Google...">
                <i class="fab fa-google"></i> Continue with Google
            </a>
            <a href="/auth/facebook" class="oauth-btn oauth-trigger" data-loading="Connecting to Facebook...">
                <i class="fab fa-facebook"></i> Continue with Facebook
            </a>
        </div>

        <div class="divider">Or create with email</div>

        <form class="auth-form auth-submit-form" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="field">
                    <label>Full Name</label>
                    <input type="text" name="full_name" placeholder="John Doe" required>
                </div>
                <div class="field">
                    <label>Username</label>
                    <input type="text" name="username" placeholder="john_chain" required>
                </div>
            </div>

            <div class="field">
                <label>Email Address</label>
                <input type="email" name="email" placeholder="john@example.com" required>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="field">
                    <label>Password</label>
                    <input type="password" name="password" placeholder="••••••••" required>
                </div>
                <div class="field">
                    <label>Age</label>
                    <input type="number" name="age" min="18" placeholder="18" required>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="field">
                    <label>Country</label>
                    <input type="text" name="country_origin" placeholder="Namibia" required>
                </div>
                <div class="field">
                    <label>City/Location</label>
                    <input type="text" name="current_location" placeholder="Windhoek" required>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div class="field">
                    <label>Town</label>
                    <input type="text" name="town" placeholder="Windhoek">
                </div>
                <div class="field">
                    <label>Region</label>
                    <input type="text" name="region" placeholder="Khomas">
                </div>
            </div>

            <div class="field">
                <label>Bio</label>
                <textarea name="bio" placeholder="Tell CHAIN who you are, what you create, or what kind of people you want to meet."></textarea>
            </div>

            <div class="field">
                <label>Profile Type</label>
                <select name="profile_type">
                    <option value="member">Regular Member</option>
                    <option value="creator">Content Creator</option>
                    <option value="host">Live Stream Host</option>
                    <option value="vendor">Business Vendor</option>
                </select>
            </div>

            <div class="field" style="display: flex; align-items: center; gap: 10px; margin-top: 10px;">
                <input type="checkbox" name="terms" id="terms" required style="width: auto;">
                <label for="terms" style="margin-bottom: 0; font-size: 13px; font-weight: 500; color: #bfc0d5; text-transform: none;">
                    I agree to the <a href="/terms">Terms of Service</a> and <a href="/privacy">Privacy Policy</a>.
                </label>
            </div>

            <button type="submit" class="primary auth-submit-btn" style="width: 100%; padding: 15px; border-radius: 12px; font-size: 16px; margin-top: 20px;">
                <span class="btn-label">Create Premium Account</span>
                <span class="btn-spinner" aria-hidden="true"></span>
            </button>
        </form>

        <div class="auth-footer">
            Already have an account? <a href="/auth/login">Log In</a>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.auth-submit-form');
    const submitBtn = document.querySelector('.auth-submit-btn');
    const triggers = document.querySelectorAll('.oauth-trigger');

    form?.addEventListener('submit', () => {
        if (!submitBtn) return;
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');
    });

    triggers.forEach(link => {
        link.addEventListener('click', () => {
            link.classList.add('loading');
            link.setAttribute('aria-disabled', 'true');
            link.style.pointerEvents = 'none';
        });
    });
});
</script>
{% endblock %}
