{% extends "base.html" %}

{% block title %}Login | Chain Premium{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="/static/css/auth_premium.css">
{% endblock %}

{% block content %}
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Welcome back</h1>
            <p>Login to continue your matches, messages, video calls, live rooms, wallet, gifts, and global dating discovery.</p>
        </div>

        {% with messages = get_flashed_messages(category_filter=['oauth_error']) %}
            {% if messages %}
                {% for message in messages %}
                <div class="error-msg">
                    <i class="fas fa-exclamation-circle"></i> {{ message }}
                </div>
                {% endfor %}
            {% endif %}
        {% endwith %}

        {% if error %}
        <div class="error-msg">
            <i class="fas fa-exclamation-circle"></i> {{ error }}
        </div>
        {% endif %}

        <div class="oauth-buttons">
            <a href="/auth/google" class="oauth-btn oauth-trigger" data-loading="Connecting to Google...">
                <i class="fab fa-google"></i> Google
            </a>
            <a href="/auth/facebook" class="oauth-btn oauth-trigger" data-loading="Connecting to Facebook...">
                <i class="fab fa-facebook"></i> Facebook
            </a>
        </div>

        <div class="divider">Or with Email / Username</div>

        <form class="auth-form auth-submit-form" method="POST">
            <div class="field">
                <label>Email or Username</label>
                <input type="text" name="login_id" placeholder="Enter your email or username" required>
            </div>

            <div class="field">
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>

            <button type="submit" class="primary auth-submit-btn" style="width: 100%; padding: 15px; border-radius: 12px; font-size: 16px; margin-top: 10px;">
                <span class="btn-label">Log In to Chain</span>
                <span class="btn-spinner" aria-hidden="true"></span>
            </button>
        </form>

        <div class="auth-footer">
            Don't have an account? <a href="/auth/register">Create account</a>
            <br><br>
            <a href="/auth/forgot-password" style="font-size: 13px; opacity: 0.6; font-weight: normal;">Forgot your password?</a>
        </div>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.auth-submit-form');
    const submitBtn = document.querySelector('.auth-submit-btn');
    const triggers = document.querySelectorAll('.oauth-trigger');

    form?.addEventListener('submit', () => {
        if (!submitBtn) return;
        submitBtn.disabled = true;
        submitBtn.classList.add('loading');
    });

    triggers.forEach(link => {
        link.addEventListener('click', () => {
            link.classList.add('loading');
            link.setAttribute('aria-disabled', 'true');
            link.style.pointerEvents = 'none';
        });
    });
});
</script>
{% endblock %}
