{% extends "base.html" %}

{% block title %}Create Profile | Chain Premium{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="/static/css/profile_premium.css">
{% endblock %}

{% block content %}
<section class="profile-form-shell">
    <div class="glass-panel form-panel">
        <div class="panel-head">
            <div>
                <p>PROFILE CREATION</p>
                <h2>Build your premium CHAIN identity</h2>
            </div>
        </div>
        {% if error %}<div class="form-error">{{ error }}</div>{% endif %}
        <form method="POST" enctype="multipart/form-data" class="profile-form-grid">
            <label><span>Full name</span><input type="text" name="full_name" value="{{ form.full_name or '' }}" required></label>
            <label><span>Username</span><input type="text" name="username" value="{{ form.username or '' }}" required></label>
            <label><span>Email</span><input type="email" name="email" value="{{ form.email or '' }}"></label>
            <label><span>Phone</span><input type="text" name="phone" value="{{ form.phone or '' }}"></label>
            <label><span>Gender</span><input type="text" name="gender" value="{{ form.gender or '' }}"></label>
            <label><span>Age</span><input type="number" name="age" value="{{ form.age or '' }}"></label>
            <label><span>Country origin</span><input type="text" name="country_origin" value="{{ form.country_origin or '' }}"></label>
            <label><span>Current location</span><input type="text" name="current_location" value="{{ form.current_location or '' }}"></label>
            <label><span>Profile type</span><input type="text" name="profile_type" value="{{ form.profile_type or 'member' }}"></label>
            <label><span>Creator category</span><input type="text" name="creator_category" value="{{ form.creator_category or '' }}"></label>
            <label><span>Relationship status</span><input type="text" name="relationship_status" value="{{ form.relationship_status or '' }}"></label>
            <label><span>Languages</span><input type="text" name="languages" value="{{ form.languages or '' }}" placeholder="English, Afrikaans"></label>
            <label class="full"><span>Interests</span><input type="text" name="interests" value="{{ form.interests or '' }}" placeholder="Music, Travel, Live shows"></label>
            <label class="full"><span>Bio</span><textarea name="bio">{{ form.bio or '' }}</textarea></label>
            <label><span>Avatar</span><input type="file" name="avatar" accept="image/*"></label>
            <label><span>Cover</span><input type="file" name="cover" accept="image/*"></label>
            <label class="checkbox"><input type="checkbox" name="is_public" checked> <span>Public profile</span></label>
            <div class="full"><button class="profile-empty-btn" type="submit">Create Premium Profile</button></div>
        </form>
    </div>
</section>
{% endblock %}
