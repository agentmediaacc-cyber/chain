<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Chain | Premium Live Social{% endblock %}</title>
    <link rel="stylesheet" href="/static/css/chain_home.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary: #ff2f7d;
            --secondary: #7c3aed;
            --accent: #00d4ff;
            --bg-dark: #050510;
            --card-bg: rgba(17, 17, 36, 0.84);
            --border: rgba(255, 255, 255, 0.1);
            --glass: rgba(5, 5, 16, 0.76);
        }

        body {
            display: flex;
            min-height: 100vh;
            background: var(--bg-dark);
            margin: 0;
            padding-bottom: 80px; /* Space for mobile nav */
        }

        * {
            box-sizing: border-box;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border);
            height: 100vh;
            position: sticky;
            top: 0;
            display: flex;
            flex-direction: column;
            padding: 24px;
            z-index: 100;
        }

        @media (max-width: 1024px) {
            .sidebar { display: none; }
        }

        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 40px;
            text-decoration: none;
            color: white;
        }

        .sidebar-brand span {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: conic-gradient(var(--primary), var(--secondary), var(--accent), var(--primary));
            display: grid;
            place-items: center;
            font-weight: 1000;
            font-size: 10px;
        }

        .sidebar-nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex: 1;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            border-radius: 14px;
            text-decoration: none;
            color: #bfc0d5;
            font-weight: 600;
            transition: 0.3s;
        }

        .sidebar-link:hover, .sidebar-link.active {
            background: rgba(255, 255, 255, 0.08);
            color: white;
        }

        .sidebar-link i {
            width: 20px;
            font-size: 18px;
        }

        /* Main Content */
        .main-container {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .top-header {
            height: 80px;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 90;
        }

        .search-bar {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid var(--border);
            border-radius: 999px;
            padding: 8px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            width: 100%;
            max-width: 400px;
        }

        .search-bar input {
            background: transparent;
            border: none;
            color: white;
            outline: none;
            width: 100%;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .notif-badge {
            position: relative;
            cursor: pointer;
            font-size: 20px;
        }

        .notif-count {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--primary);
            color: white;
            font-size: 10px;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            font-weight: bold;
        }

        /* Mobile Floating Nav */
        .mobile-nav {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(5, 5, 16, 0.85);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 999px;
            display: none;
            padding: 8px 12px;
            gap: 15px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            z-index: 1000;
        }

        @media (max-width: 1024px) {
            .mobile-nav { display: flex; }
        }

        .mobile-link {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            color: #bfc0d5;
            text-decoration: none;
            font-size: 20px;
            transition: 0.3s;
        }

        .mobile-link.active {
            background: var(--primary);
            color: white;
            box-shadow: 0 0 20px rgba(255, 47, 125, 0.5);
        }

        .mobile-link.center-btn {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            width: 60px;
            height: 60px;
            margin-top: -30px;
            border: 4px solid var(--bg-dark);
            box-shadow: 0 8px 25px rgba(255, 47, 125, 0.4);
        }

        /* Skeleton Loading */
        .skeleton {
            background: linear-gradient(90deg, #111124 25%, #1a1a35 50%, #111124 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
        }

        @keyframes loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        /* Rotating Logo */
        .rotating-logo {
            animation: spin 6s linear infinite;
        }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        .content-body {
            padding: 28px 0 0;
        }

        .empty-card {
            padding: 28px;
            border-radius: 24px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .action-cluster {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        @media (max-width: 760px) {
            .top-header {
                padding: 0 16px;
                gap: 12px;
                height: auto;
                min-height: 74px;
            }

            .search-bar {
                max-width: none;
                padding: 8px 14px;
            }

            .header-actions {
                gap: 10px;
            }

            .content-body {
                padding-top: 18px;
            }

            .mobile-nav {
                left: 16px;
                right: 16px;
                bottom: 12px;
                transform: none;
                justify-content: space-between;
                border-radius: 24px;
                padding: 8px;
            }

            .mobile-link {
                width: 46px;
                height: 46px;
                font-size: 18px;
            }

            .mobile-link.center-btn {
                width: 54px;
                height: 54px;
                margin-top: -20px;
            }
        }

    </style>
    {% block extra_css %}{% endblock %}
</head>
<body>
    <!-- Sidebar -->
    <aside class="sidebar">
        <a href="/" class="sidebar-brand">
            <span class="rotating-logo">CHAIN</span>
            <b>CHAIN PREMIUM</b>
        </a>
        
        <nav class="sidebar-nav">
            <a href="/" class="sidebar-link active"><i class="fas fa-home"></i> Home</a>
            <a href="/discover/" class="sidebar-link"><i class="fas fa-compass"></i> Discover</a>
            <a href="/live/" class="sidebar-link"><i class="fas fa-video"></i> Live Now</a>
            <a href="/discover/trending" class="sidebar-link"><i class="fas fa-fire"></i> Trending</a>
            <a href="/notifications/" class="sidebar-link"><i class="fas fa-bell"></i> Notifications</a>
            <a href="/chat/" class="sidebar-link"><i class="fas fa-comment"></i> Messages</a>
            <a href="/favorites" class="sidebar-link"><i class="fas fa-heart"></i> Favorites</a>
            <a href="/history" class="sidebar-link"><i class="fas fa-history"></i> History</a>
            <hr style="border: none; border-top: 1px solid var(--border); margin: 15px 0;">
            <a href="/wallet/" class="sidebar-link"><i class="fas fa-wallet"></i> Wallet & Gifts</a>
            <a href="/live/studio" class="sidebar-link"><i class="fas fa-plus-circle"></i> Create Live</a>
            <a href="{{ '/profile/' if g_current else '/profile/create' }}" class="sidebar-link"><i class="fas fa-user-circle"></i> My Profile</a>
        </nav>

        <div class="sidebar-footer" style="margin-top: 20px;">
            {% if g_current %}
            <a href="/auth/logout" class="sidebar-link"><i class="fas fa-sign-out-alt"></i> Sign Out</a>
            {% else %}
            <a href="/auth/login" class="sidebar-link"><i class="fas fa-sign-in-alt"></i> Login/Register</a>
            {% endif %}
        </div>
    </aside>

    <!-- Main Content -->
    <main class="main-container">
        <header class="top-header">
            <form class="search-bar" action="/search" method="get">
                <i class="fas fa-search" style="color: #666;"></i>
                <input type="text" name="q" value="{{ request.args.get('q', '') }}" placeholder="Search creators, rooms, posts...">
            </form>

            <div class="header-actions">
                <a href="/wallet/" class="sidebar-link" style="padding: 8px 15px; background: rgba(0, 212, 255, 0.1); border: 1px solid rgba(0, 212, 255, 0.2); color: var(--accent);">
                    <i class="fas fa-coins"></i> <span>{{ g_wallet_balance or '0.00' }}</span>
                </a>
                <a href="/notifications/" class="notif-badge" style="text-decoration: none; color: white;">
                    <i class="fas fa-bell"></i>
                    <span class="notif-count" {% if not g_unread_count %}style="display: none;"{% endif %}>{{ g_unread_count or 0 }}</span>
                </a>
                <a href="{{ '/profile/' if g_current else '/profile/create' }}" class="user-profile" style="width: 40px; height: 40px; border-radius: 50%; background: var(--card-bg); border: 1px solid var(--border); display: grid; place-items: center; overflow: hidden; text-decoration: none; color: white;">
                    {% if g_current and g_current.avatar_url %}
                    <img src="{{ g_current.avatar_url }}" alt="Profile" style="width: 100%; height: 100%; object-fit: cover;">
                    {% else %}
                    <i class="fas fa-user"></i>
                    {% endif %}
                </a>
            </div>
        </header>

        <div class="content-body">
            {% block content %}{% endblock %}
        </div>
    </main>

    <!-- Mobile Nav -->
    <nav class="mobile-nav">
        <a href="/" class="mobile-link active"><i class="fas fa-home"></i></a>
        <a href="/discover/" class="mobile-link"><i class="fas fa-compass"></i></a>
        <a href="/live/studio" class="mobile-link center-btn"><i class="fas fa-plus"></i></a>
        <a href="/notifications/" class="mobile-link"><i class="fas fa-bell"></i></a>
        <a href="{{ '/profile/' if g_current else '/profile/create' }}" class="mobile-link"><i class="fas fa-user"></i></a>
    </nav>

    <script src="/static/js/main.js"></script>
    {% block extra_js %}{% endblock %}
</body>
</html>
