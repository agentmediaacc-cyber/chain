{% extends "base.html" %}

{% block title %}Marketplace Item | CHAIN{% endblock %}

{% block content %}
<section style="max-width: 900px; margin: 0 auto; padding: 20px 16px 80px;">
    <article style="padding:24px; border-radius:28px; background: rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08);">
        <p style="margin:0 0 8px; color:#f4a5bd;">{{ item.item_type|replace('_', ' ')|title }}</p>
        <h1 style="margin:0 0 10px;">{{ item.title }}</h1>
        <p style="color:#cbbecf;">{{ item.description or 'No description provided yet.' }}</p>
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:16px;">
            <span>{{ item.price_coins or 0 }} coins</span>
            <span>{{ item.approval_status or item.moderation_status or 'pending' }}</span>
            <span>{{ 'Locked until purchase' if item.is_premium_locked else 'Open preview' }}</span>
        </div>
        <form method="POST" action="/marketplace/purchase/{{ item.id }}" style="margin-top:18px;">
            <button type="submit" class="primary">Purchase item</button>
        </form>
    </article>
</section>
{% endblock %}
