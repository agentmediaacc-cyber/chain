{% extends "base.html" %}

{% block title %}CHAIN Wallet{% endblock %}

{% block content %}
<section style="max-width: 1200px; margin: 0 auto; padding: 20px 16px 80px;">
    <div style="display:grid; grid-template-columns: 1.1fr .9fr; gap:16px; margin-bottom:16px;">
        <article style="padding:24px; border-radius:28px; background: linear-gradient(135deg, rgba(255,77,141,.16), rgba(141,77,255,.14), rgba(10,7,17,.96)); border:1px solid rgba(255,255,255,.1);">
            <p style="margin:0 0 8px; color:#f4a5bd; font-size:12px; font-weight:900; text-transform:uppercase; letter-spacing:.14em;">Wallet</p>
            <h1 style="margin:0 0 10px; font-size:42px; line-height:1;">Coins, top-ups and payouts.</h1>
            <p style="margin:0 0 18px; color:#cbbecf;">1 CHAIN coin = NAD 5. Manual top-ups and withdrawals are reviewed by admin before completion.</p>
            <div style="display:flex; gap:12px; flex-wrap:wrap;">
                <a href="/wallet/top-up" class="primary">Request top-up</a>
                <a href="/wallet/withdraw" class="secondary">Withdraw coins</a>
                <a href="/wallet/pin" class="secondary">Wallet PIN</a>
            </div>
        </article>
        <article style="padding:24px; border-radius:28px; background: rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08);">
            <div style="display:grid; gap:12px;">
                <div><span style="color:#cbbecf;">Coin balance</span><strong style="display:block; font-size:32px;">{{ wallet.coin_balance or wallet.available_balance or 0 }}</strong></div>
                <div><span style="color:#cbbecf;">Available balance</span><strong style="display:block;">{{ wallet.available_balance or wallet.coin_balance or 0 }} coins</strong></div>
                <div><span style="color:#cbbecf;">Pending withdrawals</span><strong style="display:block;">{{ wallet.pending_withdrawal_balance or wallet.pending_withdrawal or 0 }} coins</strong></div>
                <div><span style="color:#cbbecf;">Gift earnings</span><strong style="display:block;">{{ wallet.gift_earnings or 0 }}</strong></div>
            </div>
        </article>
    </div>

    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
        <section style="padding:22px; border-radius:28px; background: rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08);">
            <h2 style="margin:0 0 14px;">Recent top-up requests</h2>
            {% for row in topups %}
            <div style="padding:12px 0; border-top:1px solid rgba(255,255,255,.06);">
                <strong>{{ row.reference }}</strong>
                <div style="color:#cbbecf;">{{ row.amount_nad }} NAD · {{ row.method }} · {{ row.status }}</div>
            </div>
            {% else %}
            <p style="margin:0; color:#cbbecf;">No top-up requests yet.</p>
            {% endfor %}
        </section>
        <section style="padding:22px; border-radius:28px; background: rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08);">
            <h2 style="margin:0 0 14px;">Recent withdrawals</h2>
            {% for row in withdrawals %}
            <div style="padding:12px 0; border-top:1px solid rgba(255,255,255,.06);">
                <strong>{{ row.coins_redeemed }} coins</strong>
                <div style="color:#cbbecf;">{{ row.amount_nad }} NAD · {{ row.destination_method }} · {{ row.status }}</div>
            </div>
            {% else %}
            <p style="margin:0; color:#cbbecf;">No withdrawal requests yet.</p>
            {% endfor %}
        </section>
    </div>
</section>
{% endblock %}
